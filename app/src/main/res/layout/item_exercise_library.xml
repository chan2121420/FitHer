<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/FitHer.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/tvName" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" android:layout_marginBottom="4dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvCategory" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="?attr/colorPrimary" android:background="@drawable/bg_info_chip"
                        android:paddingStart="7dp" android:paddingEnd="7dp" android:paddingTop="2dp" android:paddingBottom="2dp"
                        android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/tvType" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="?attr/colorOnSurface" android:alpha="0.5" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/tvDefaultReps" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp"
                        android:textColor="?attr/colorOnSurface" android:alpha="0.6" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/tvCalories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="@color/orange_accent"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tvDifficulty" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="@color/success" android:layout_marginEnd="8dp" />
                    <TextView android:id="@+id/tvEquipment" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="?attr/colorOnSurface" android:alpha="0.5"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <ImageView android:id="@+id/ivExpandArrow" android:layout_width="22dp"
                android:layout_height="22dp" android:src="@drawable/ic_expand_more"
                android:alpha="0.4" />
        </LinearLayout>

        <!-- Expanded layout -->
        <LinearLayout android:id="@+id/expandedLayout" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:visibility="gone" android:layout_marginTop="12dp">

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/gray_light" android:layout_marginBottom="12dp" />

            <TextView android:id="@+id/tvMuscles" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="?attr/colorPrimary" android:textStyle="bold" android:layout_marginBottom="8dp" />

            <TextView android:id="@+id/tvSecondaryMuscles" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="?attr/colorOnSurface" android:alpha="0.6"
                android:layout_marginBottom="10dp" android:visibility="gone" />

            <TextView android:id="@+id/tvDescription" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="?attr/colorOnSurface" android:alpha="0.75"
                android:lineSpacingMultiplier="1.4" android:layout_marginBottom="12dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HOW TO DO IT" style="@style/FitHer.SectionTitle" android:layout_marginBottom="6dp" />
            <TextView android:id="@+id/tvInstructions" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="?attr/colorOnSurface" android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="12dp" />

            <TextView android:id="@+id/tvTips" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_coach_note"
                android:padding="10dp" android:textSize="12sp" android:textColor="?attr/colorPrimary"
                android:lineSpacingMultiplier="1.4" android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <TextView android:id="@+id/tvMistakes" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_mistake_note"
                android:padding="10dp" android:textSize="12sp" android:textColor="@color/error"
                android:lineSpacingMultiplier="1.4" android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <TextView android:id="@+id/tvBreathing" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_info_chip"
                android:padding="10dp" android:textSize="12sp" android:textColor="?attr/colorOnSurface"
                android:alpha="0.8" android:layout_marginBottom="8dp" android:visibility="gone" />

            <TextView android:id="@+id/tvProgression" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_info_chip"
                android:padding="10dp" android:textSize="12sp" android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="12dp" android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFullTutorial"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Full Tutorial →"
                android:textSize="13sp"
                style="@style/FitHer.Button.Outline" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>