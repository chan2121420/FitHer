<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_header_gradient"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white"
            app:navigationIcon="@drawable/ic_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Demo image/placeholder area -->
            <ImageView
                android:id="@+id/imgExerciseDemo"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground" />

            <!-- Category stripe -->
            <View
                android:id="@+id/viewCategoryStripe"
                android:layout_width="match_parent"
                android:layout_height="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row -->
                <TextView
                    android:id="@+id/tvExerciseName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:background="@drawable/bg_pill"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="3dp" android:paddingBottom="3dp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tvDifficulty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tvType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <!-- Quick stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_card_solid" android:padding="12dp" android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvCaloriesPerMin" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Calories" android:textSize="10sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_card_solid" android:padding="12dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvEquipment" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="11sp"
                            android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Equipment" android:textSize="10sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_card_solid" android:padding="12dp" android:layout_marginStart="6dp">
                        <TextView android:id="@+id/tvPrimaryMuscles" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="10sp"
                            android:textStyle="bold" android:textColor="?attr/colorPrimary"
                            android:maxLines="2" android:ellipsize="end" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Muscles" android:textSize="10sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="20dp" />

                <!-- Instructions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOW TO DO IT"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingMultiplier="1.7"
                    android:layout_marginBottom="20dp" />

                <!-- Coaching Tips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COACHING TIPS"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/FitHer.Card">
                    <TextView
                        android:id="@+id/tvCoachingTips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:lineSpacingMultiplier="1.5" />
                </androidx.cardview.widget.CardView>

                <!-- Common Mistakes -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMMON MISTAKES"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/FitHer.Card">
                    <TextView
                        android:id="@+id/tvCommonMistakes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textSize="14sp"
                        android:textColor="@color/error"
                        android:lineSpacingMultiplier="1.5" />
                </androidx.cardview.widget.CardView>

                <!-- Breathing -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BREATHING"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvBreathing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_info_chip"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp" />

                <!-- Also works -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECONDARY MUSCLES"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSecondaryMuscles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.7"
                    android:layout_marginBottom="20dp" />

                <!-- Progression -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAKE IT HARDER"
                    style="@style/FitHer.SectionTitle"
                    android:layout_marginBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    style="@style/FitHer.Card">
                    <TextView
                        android:id="@+id/tvProgression"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary"
                        android:lineSpacingMultiplier="1.5" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>