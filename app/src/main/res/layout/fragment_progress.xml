<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/gray_dark"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Workouts" android:textSize="11sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvTotalWorkouts" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/teal_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Streak" android:textSize="11sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvCurrentStreak" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 days"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/purple_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kcal/wk" android:textSize="11sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvWeekCalories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 kcal"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/coral_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Latest measurements -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LATEST MEASUREMENTS" android:textSize="11sp" android:letterSpacing="0.1"
            android:textStyle="bold" android:textColor="@color/gray_mid" android:layout_marginBottom="10dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/FitHer.Card">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Glutes"
                        android:textSize="13sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvLatestGlutes" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/teal_primary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Hips"
                        android:textSize="13sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvLatestHips" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/purple_primary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Waist"
                        android:textSize="13sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvLatestWaist" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/coral_primary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Weight"
                        android:textSize="13sp" android:textColor="@color/gray_mid" />
                    <TextView android:id="@+id/tvLatestWeight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/gray_dark" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogMeasurement"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Log Measurements"
            android:layout_marginBottom="24dp"
            style="@style/FitHer.Button.Primary" />

        <!-- Charts -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="GLUTES" android:textSize="11sp" android:letterSpacing="0.1"
            android:textStyle="bold" android:textColor="@color/teal_primary" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartGlutes"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HIPS" android:textSize="11sp" android:letterSpacing="0.1"
            android:textStyle="bold" android:textColor="@color/purple_primary" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartHips"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WAIST" android:textSize="11sp" android:letterSpacing="0.1"
            android:textStyle="bold" android:textColor="@color/coral_primary" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartWaist"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEIGHT" android:textSize="11sp" android:letterSpacing="0.1"
            android:textStyle="bold" android:textColor="@color/gray_mid" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartWeight"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
