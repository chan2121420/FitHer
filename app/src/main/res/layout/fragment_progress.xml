<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:paddingTop="12dp"
            android:paddingBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="6dp" style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Workouts" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6" />
                    <TextView android:id="@+id/tvTotalWorkouts" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="26sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp" style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Streak" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6" />
                    <TextView android:id="@+id/tvCurrentStreak" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 days"
                        android:textSize="26sp" android:textStyle="bold" android:textColor="@color/orange_accent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" style="@style/FitHer.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kcal/wk" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6" />
                    <TextView android:id="@+id/tvWeekCalories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="26sp" android:textStyle="bold" android:textColor="@color/teal_accent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LATEST MEASUREMENTS" style="@style/FitHer.SectionTitle" android:layout_marginBottom="10dp" />

        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp" style="@style/FitHer.Card">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Glutes" android:textSize="14sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6"/>
                    <TextView android:id="@+id/tvLatestGlutes" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Hips" android:textSize="14sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6"/>
                    <TextView android:id="@+id/tvLatestHips" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Waist" android:textSize="14sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6"/>
                    <TextView android:id="@+id/tvLatestWaist" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Weight" android:textSize="14sp" android:textColor="?attr/colorOnSurface" android:alpha="0.6"/>
                    <TextView android:id="@+id/tvLatestWeight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogMeasurement"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Log Measurements"
            android:layout_marginBottom="28dp"
            style="@style/FitHer.Button.Primary" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="GLUTES" style="@style/FitHer.SectionTitle"
            android:textColor="?attr/colorPrimary" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart android:id="@+id/chartGlutes"
            android:layout_width="match_parent" android:layout_height="160dp" android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HIPS" style="@style/FitHer.SectionTitle"
            android:textColor="@color/orange_accent" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart android:id="@+id/chartHips"
            android:layout_width="match_parent" android:layout_height="160dp" android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WAIST" style="@style/FitHer.SectionTitle"
            android:textColor="@color/teal_accent" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart android:id="@+id/chartWaist"
            android:layout_width="match_parent" android:layout_height="160dp" android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEIGHT" style="@style/FitHer.SectionTitle"
            android:textColor="@color/success" android:layout_marginBottom="8dp" />
        <com.github.mikephil.charting.charts.LineChart android:id="@+id/chartWeight"
            android:layout_width="match_parent" android:layout_height="160dp" android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>