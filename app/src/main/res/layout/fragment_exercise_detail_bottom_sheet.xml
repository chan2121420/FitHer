<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp" android:background="@drawable/bg_sheet_handle" />

    <TextView android:id="@+id/tvSheetTitle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="17sp" android:textStyle="bold"
        android:textColor="?attr/colorOnSurface" android:padding="18dp" android:paddingBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExercises"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingBottom="32dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false" />
</LinearLayout>