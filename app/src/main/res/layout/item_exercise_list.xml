<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp" android:paddingBottom="12dp"
    android:paddingStart="4dp" android:paddingEnd="4dp">

    <View android:layout_width="4dp" android:layout_height="38dp"
        android:background="?attr/colorPrimary" android:layout_marginEnd="12dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvExerciseName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="2dp">
            <TextView android:id="@+id/tvMuscles" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="?attr/colorOnSurface" android:alpha="0.6" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvType" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="?attr/colorPrimary" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvDifficulty" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="@color/success"/>
        </LinearLayout>
        <TextView android:id="@+id/tvNotes" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textColor="?attr/colorPrimary" android:layout_marginTop="3dp"
            android:visibility="gone" />
        <TextView android:id="@+id/tvRest" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="10sp"
            android:textColor="?attr/colorOnSurface" android:alpha="0.4"
            android:layout_marginTop="2dp" android:visibility="gone" />
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end" android:layout_marginStart="8dp">
        <TextView android:id="@+id/tvSets" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textColor="?attr/colorOnSurface" android:alpha="0.5" android:gravity="end" />
        <TextView android:id="@+id/tvReps" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
            android:textColor="?attr/colorPrimary" android:layout_marginTop="2dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTutorial"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="How?"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            style="@style/FitHer.Button.Text"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>