<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FitHer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/pink_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/gray_dark</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/purple_dark</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="bottomNavigationStyle">@style/Widget.FitHer.BottomNav</item>
        <item name="materialButtonStyle">@style/FitHer.Button.Primary</item>
        <item name="chipStyle">@style/FitHer.Chip</item>
    </style>

    <style name="Theme.FitHer.Splash" parent="Theme.FitHer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/purple_primary</item>
        <item name="android:windowBackground">@color/purple_primary</item>
    </style>

    <style name="Widget.FitHer.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="android:background">@color/colorSurface</item>
        <item name="elevation">8dp</item>
        <item name="itemRippleColor">@color/purple_surface</item>
    </style>

    <style name="FitHer.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/purple_medium</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="FitHer.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_primary</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="rippleColor">@color/purple_surface</item>
    </style>

    <style name="FitHer.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/purple_primary</item>
        <item name="rippleColor">@color/purple_surface</item>
    </style>

    <style name="FitHer.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/gray_light</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
    </style>

    <style name="FitHer.Card.Elevated" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
    </style>

    <style name="FitHer.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/purple_primary</item>
        <item name="hintTextColor">@color/purple_primary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <style name="FitHer.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/purple_surface</item>
        <item name="chipStrokeColor">@color/purple_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="checkedIconTint">@color/purple_primary</item>
    </style>

    <style name="FitHer.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/gray_mid</item>
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>