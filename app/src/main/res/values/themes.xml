<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FitHer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_primary</item>
        <item name="colorSecondaryVariant">@color/purple_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/gray_dark</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/teal_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="bottomNavigationStyle">@style/Widget.FitHer.BottomNav</item>
    </style>

    <style name="Theme.FitHer.Splash" parent="Theme.FitHer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/teal_primary</item>
        <item name="android:windowBackground">@color/teal_primary</item>
    </style>

    <style name="Widget.FitHer.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="android:background">@color/white</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="FitHer.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="FitHer.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/teal_primary</item>
        <item name="android:textColor">@color/teal_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="FitHer.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#E8E6E0</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="FitHer.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/teal_primary</item>
        <item name="hintTextColor">@color/teal_primary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>
</resources>
