<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FitHer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_primary</item>
        <item name="colorSecondaryVariant">@color/purple_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/colorSurfaceDark</item>
        <item name="colorOnSurface">@color/colorOnBackgroundDark</item>
        <item name="android:colorBackground">@color/colorBackgroundDark</item>
        <item name="android:windowBackground">@color/colorBackgroundDark</item>
        <item name="android:statusBarColor">@color/gray_dark</item>
        <item name="android:navigationBarColor">@color/gray_dark</item>
        <item name="bottomNavigationStyle">@style/Widget.FitHer.BottomNavDark</item>
    </style>

    <style name="Widget.FitHer.BottomNavDark" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="android:background">@color/gray_dark</item>
        <item name="elevation">8dp</item>
    </style>
</resources>
